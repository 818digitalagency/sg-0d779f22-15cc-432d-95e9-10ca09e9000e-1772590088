# App Configuration
NEXT_PUBLIC_APP_NAME=Opportunity Finder
NEXT_PUBLIC_APP_URL=https://opportunityfinder.ca

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Google Maps (for map features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Optional: Email Service (SendGrid, AWS SES, or Postmark)
SENDGRID_API_KEY=your_sendgrid_api_key

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_EMAIL_TRACKING=true
NEXT_PUBLIC_ENABLE_EXPORTS=true

# Rate Limits
MAX_LEADS_PER_USER=10000
MAX_EMAILS_PER_DAY=1000

# Database (if using external PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/opportunityfinder

# Security
SESSION_SECRET=your_session_secret_key_here
JWT_SECRET=your_jwt_secret_key_here

# Development
NODE_ENV=development
LOG_LEVEL=info

# Email Service Configuration (choose one)
# SendGrid (Recommended)
NEXT_PUBLIC_SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
NEXT_PUBLIC_FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_FROM_NAME=Your Company Name

# OR AWS SES (Advanced)
NEXT_PUBLIC_AWS_SES_ACCESS_KEY=your_aws_access_key_here
NEXT_PUBLIC_AWS_SES_SECRET_KEY=your_aws_secret_key_here
NEXT_PUBLIC_AWS_SES_REGION=us-east-1