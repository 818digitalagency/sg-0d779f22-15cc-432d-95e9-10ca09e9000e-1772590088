# App Configuration
NEXT_PUBLIC_APP_NAME=Opportunity Finder
NEXT_PUBLIC_APP_URL=https://opportunityfinder.ca
NEXT_PUBLIC_API_URL=https://api.opportunityfinder.ca

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/opportunity_finder
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis (Queue & Cache)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email Service (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@opportunityfinder.ca
SENDGRID_FROM_NAME=Opportunity Finder

# Email Service (AWS SES - Alternative)
AWS_SES_REGION=ca-central-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=noreply@opportunityfinder.ca

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d
NEXTAUTH_SECRET=your-nextauth-secret-change-this
NEXTAUTH_URL=https://opportunityfinder.ca

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Web Scraping
SCRAPER_USER_AGENT=OpportunityFinderBot/1.0 (+https://opportunityfinder.ca/bot)
SCRAPER_RATE_LIMIT_MS=2000
SCRAPER_MAX_CONCURRENT=5
SCRAPER_TIMEOUT_MS=30000

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Monitoring & Analytics
SENTRY_DSN=
NEXT_PUBLIC_GA_TRACKING_ID=
MIXPANEL_TOKEN=

# Feature Flags
ENABLE_EMAIL_TRACKING=true
ENABLE_AI_FEATURES=true
ENABLE_MAP_CLUSTERING=true
ENABLE_EXPORT=true

# Compliance
CASL_COMPLIANCE_MODE=true
DATA_RETENTION_DAYS=730

# Development
NODE_ENV=production
LOG_LEVEL=info