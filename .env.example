# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Application Configuration
# For Vercel: Use your Vercel deployment URL (e.g., https://your-app.vercel.app)
# For local: Use http://localhost:3000
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_NAME=Opportunity Finder

# Email Service Configuration (OPTIONAL - Choose ONE)
# Option 1: SendGrid (Recommended for beginners)
NEXT_PUBLIC_SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
# Option 2: AWS SES (Advanced)
NEXT_PUBLIC_AWS_SES_ACCESS_KEY=your_aws_access_key_here
NEXT_PUBLIC_AWS_SES_SECRET_KEY=your_aws_secret_key_here
NEXT_PUBLIC_AWS_SES_REGION=us-east-1

# Email Settings (Required if using email features)
NEXT_PUBLIC_FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_FROM_NAME=Opportunity Finder

# Google Maps Configuration (OPTIONAL)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here